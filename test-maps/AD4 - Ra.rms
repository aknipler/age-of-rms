#const FOREST_SIZE_PERCENT 100
#const FOREST_CL_FACTOR 30
#const FOREST_BASE_SIZE 5

/* actor areas */
#const ACT_AREA_SCOUT 3032


/* terrains */
#const PL_TERRAIN 60 /* jungle grass */
#const BASE_TERRAIN 56 /* rain forest */
#const BASE_TERRAIN_MASK 0
#const BASE_TERRAIN_MASK2 12
#const CENTER_FOREST_TERRAIN 17 /* jungle themed, the actual trees */

<CONNECTION_GENERATION>
/* create_connect_all_lands */
create_connect_to_nonplayer_land
{
  replace_terrain CENTER_FOREST_TERRAIN CENTER_NONBUILDABLE_TERRAIN 
  replace_terrain TERR_UNDERBRUSH CENTER_NONBUILDABLE_TERRAIN 
  /* replace_terrain PL_TERRAIN CENTER_HOLE_TERRAIN  */
  terrain_cost CENTER_FOREST_TERRAIN 11
  terrain_cost CENTER_HOLE_TERRAIN 2
  terrain_cost TERR_UNDERBRUSH 4
  terrain_cost TERR_NEUTRAL 10
  terrain_cost PL_TERRAIN 2
  terrain_cost CENTER_NONBUILDABLE_TERRAIN 3 /* this is only around the center holes */
  terrain_cost BASE_TERRAIN 0
  terrain_size CENTER_NONBUILDABLE_TERRAIN 1 1
  /* terrain_size PL_TERRAIN 1 0 */
}









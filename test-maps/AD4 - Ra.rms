/* default sizes */
if MAPSIZE_MINI			#const MAPSIZE 80 /* */
elseif MAPSIZE_TINY		#const MAPSIZE 120 /* 2 */
elseif MAPSIZE_SMALL		#const MAPSIZE 144 /* 3 */
elseif MAPSIZE_MEDIUM		#const MAPSIZE 168 /* 4 */
elseif MAPSIZE_NORMAL		#const MAPSIZE 200 /* 6 */
elseif MAPSIZE_LARGE		#const MAPSIZE 220 /* 8 */
elseif MAPSIZE_HUGE		#const MAPSIZE 240 /* */
elseif MAPSIZE_GIANT		#const MAPSIZE 252 /* */
elseif MAPSIZE_MASSIVE		#const MAPSIZE 276 /* */
elseif MAPSIZE_ENORMOUS		#const MAPSIZE 300 /* */
elseif MAPSIZE_COLOSSAL		#const MAPSIZE 320 /* */
elseif MAPSIZE_INCREDIBLE	#const MAPSIZE 360 /* */
elseif MAPSIZE_MONSTROUS	#const MAPSIZE 400 
elseif MAPSIZE_LUDICROUS	#const MAPSIZE 480 
else				#const MAPSIZE 260 
endif

/* for area scaling */
#const MAPAREA (MAPSIZE * MAPSIZE)


/* #define DEBUGGING */


/* math constants */
#const HOLE_FOREST_BORDERS 24
#const FOREST_BORDERS 34
#const NEUTRAL_BORDERS 21
#const PL_LAND_TILES (MAPAREA / 200)
#const PL_LAND_ZONE_AVOID 12
#const FOREST_ZONE_AVOID 6
/* #const FOREST_HOLE_LAND_DISTANCE 22 */
#const FOREST_HOLE_ZONE_AVOID 5
#const PL_BASE_SIZE 7
#const CENTER_HOLE_TILES 60
#const CENTER_HOLE_BASE_SIZE 4
#const CENTER_HOLE_SPACING 9
#const CENTER_HOLD_DIST_TO_NEUTRAL 9
#const CENTER_HOLD_DIST_TO_PL 18
#const LAND_BACKSTOPPER_TILES (MAPAREA / 77)
#const NEUTRAL_BORDER_FUZZ 12
#const FOREST_BORDER_FUZZ 25

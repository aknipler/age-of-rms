#const TERR_TEMP_CENTER_NONBUILDABLE 25
#const TEMP_CENTER_FOREST_TERRAIN 24


/* objects */
#const ONGRID_PLACEHOLDER 1613

#const MAKE_CENTER_HOLE_TERRAIN 1639
#const MAKE_FOREST_TERRAIN 1650
#const CENTER_FOREST_OBJS 414 /* jungle theme */

#const STRAGGLER_TREES 414 /* jungle stragglers */

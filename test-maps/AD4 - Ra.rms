#const HUNTABLE 1896 /* argali */
#const HERDABLE 1060 /* goat */
#const LURABLE 48 /* boar */
#const BERRIES 1059 /* orange bush */


/* cosmetic objects */
#const GRASS_PATCH 301

#const BONFIRE 304
#const FENCE_RUBBLE 1065
#const PLANT_JUNGLE 1351
#const PLANT_UNDERBRUSH_TROPICAL 1352
#const PLANT_UNDERBRUSH 1353
#const PLANT_RAINFOREST 1354
#const PLANT_UNDERBRUSH_RAINFOREST 1355
#const GRASS_GREEN 1358
#const GRASS_DRY 1359
#const PLANT_BUSH_GREEN 1360
#const PLANT_SHRUB_GREEN 1362
#const PLANT_SHRUB_DRY 1363
#const PLANT_WEEDS 1364
#const PLANT_DEAD 1365
#const PLANT_FLOWERS 1366


/* Make it so that fence rubble does not disappear */
effect_amount GAIA_SET_ATTRIBUTE FENCE_RUBBLE ATTR_STORAGE_VALUE 30000

/* Make it so that the forests can't be quickly removed by players using building foundations */
/* used for making the pathways to the holes */
effect_percent SET_ATTRIBUTE MAKE_CENTER_HOLE_TERRAIN ATTR_RADIUS_1 50 /* make it a 1x1 object */
effect_percent SET_ATTRIBUTE MAKE_CENTER_HOLE_TERRAIN ATTR_RADIUS_2 50 /* make it a 1x1 object */
effect_amount SET_ATTRIBUTE MAKE_CENTER_HOLE_TERRAIN ATTR_FOUNDATION_TERRAIN CENTER_HOLE_TERRAIN_MASK /* jungle underbrush */
effect_amount SET_ATTRIBUTE MAKE_CENTER_HOLE_TERRAIN ATTR_FOG_FLAG 0 
effect_amount SET_ATTRIBUTE MAKE_CENTER_HOLE_TERRAIN ATTR_HITPOINTS 0  /* No health */
/* effect_amount SET_ATTRIBUTE MAKE_CENTER_HOLE_TERRAIN ATTR_STANDING_GRAPHIC 11202 So that if seen in a start of game revealer, the artifact it leaves is much harder to see */  

effect_percent SET_ATTRIBUTE MAKE_FOREST_TERRAIN ATTR_RADIUS_1 50 /* make it a 1x1 object */
effect_percent SET_ATTRIBUTE MAKE_FOREST_TERRAIN ATTR_RADIUS_2 50 /* make it a 1x1 object */
effect_amount SET_ATTRIBUTE MAKE_FOREST_TERRAIN ATTR_FOUNDATION_TERRAIN 77 /* jungle underbrush */ 
effect_amount SET_ATTRIBUTE MAKE_FOREST_TERRAIN ATTR_STANDING_GRAPHIC 12263  /* So that if seen in a start of game revealer, the artifact it leaves is much harder to see */
effect_amount SET_ATTRIBUTE MAKE_FOREST_TERRAIN ATTR_FOG_FLAG 0  /* So that if seen in a start of game revealer, the artifact it leaves is much harder to see */
effect_amount SET_ATTRIBUTE MAKE_FOREST_TERRAIN ATTR_HITPOINTS 0  /* No health */


/* make it so that flags disappear at the start of the game */
effect_amount SET_ATTRIBUTE FLAG_B ATTR_HITPOINTS 0
effect_amount SET_ATTRIBUTE FLAG_C ATTR_HITPOINTS 0
effect_amount SET_ATTRIBUTE FLAG_D ATTR_HITPOINTS 0
effect_amount SET_ATTRIBUTE ONGRID_PLACEHOLDER_LAND ATTR_HITPOINTS 0
effect_amount SET_ATTRIBUTE ONGRID_PLACEHOLDER ATTR_HITPOINTS 0

<PLAYER_SETUP>
grouped_by_team
/* direct_placement */
behavior_version 1



<LAND_GENERATION>

base_terrain BASE_TERRAIN_TEMP
/* base_terrain CENTER_FOREST_TERRAIN */

create_player_lands 
{
    terrain_type TEMP_PL_TERRAIN
    circle_radius 19
    base_size 7
    land_percent 0
}

<ELEVATION_GENERATION>

create_elevation 2
{
  base_terrain          BASE_TERRAIN 
  number_of_tiles       365      
  number_of_clumps      3   
  spacing               0         
  enable_balanced_elevation   
  set_scale_by_groups  
}




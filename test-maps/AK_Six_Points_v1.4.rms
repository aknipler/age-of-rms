/* Created by Captain Kniples the Fourth */
/* For funsies */
/* Created 2024 05 05 */
/* This is a 4v4 map only */


/* ******************************************************************************************************
 * This map is designed around the idea of water chokepoints meeting buildable terrain. Hopefully this  *
 * Allows for some really interesting gameplay.                                                         *
 ****************************************************************************************************** */



<PLAYER_SETUP>
direct_placement
behavior_version 1


#const GRASS_CLIFFS 16



<LAND_GENERATION>

base_terrain WATER



/* Top and Bottom trade routes  */
create_land
{
  terrain_type                    MED_WATER 
  base_size                       4
  land_percent                    100
  land_position                   50 10
  border_fuzziness                8
  bottom_border                   88
  land_id                         1
}

create_land
{
  terrain_type                    DEEP_WATER 
  base_size                       2
  land_percent                    100
  land_position                   50 89
  border_fuzziness                8
  top_border                      88
  land_id                         2
}

/* Connection between midlands and trade routes */
create_land
{
  terrain_type                    SHALLOW 
  base_size                       2
  land_percent                    100
  if TINY_MAP
    land_position                   50 15
  else
    land_position                   50 14
  endif 
  border_fuzziness                100
  bottom_border                   70
  left_border                     49
  right_border                    49
}

create_land
{
  terrain_type                    SHALLOW 
  base_size                       2
  land_percent                    100
  land_position                   50 86
  border_fuzziness                100
  top_border                      70
  left_border                     49
  right_border                    49
  zone                            1
}


/* Buildable shallows on chokepoints of map */
/* Left Top */


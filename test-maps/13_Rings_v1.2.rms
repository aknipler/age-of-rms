  create_terrain BROWN_WATER { base_terrain MUDDY_SHALLOW number_of_tiles 33 number_of_clumps 22 terrain_mask 1 }
  create_terrain BROWN_WATER { base_terrain MUD number_of_tiles 300 number_of_clumps 8 terrain_mask 1 }

/* Map Resources */ 
/* extra WILDLIFE */
create_object DLC_ZEBRA 
{
    terrain_to_place_on               BASE_TERRAIN
    number_of_objects                 5
    if TINY_MAP
      number_of_groups                  rnd(5,8)
    else
      number_of_groups                  rnd(9,12)
    endif

    min_distance_group_placement      3

    if TINY_MAP
      temp_min_distance_group_placement 20
    elseif MEDIUM_MAP
      temp_min_distance_group_placement 24
    else
      temp_min_distance_group_placement 34
    endif

    max_distance_to_other_zones       3
    avoid_forest_zone                 2
    if TINY_MAP 
        min_distance_to_map_edge          47
    elseif MEDIUM_MAP 
        min_distance_to_map_edge          68
    elseif LARGE_MAP 
        min_distance_to_map_edge          80
    elseif HUGE_MAP
        min_distance_to_map_edge          2
    endif
    min_distance_to_players           35
    set_tight_grouping
    set_gaia_object_only
}
create_object DLC_ELEPHANT 
{
    terrain_to_place_on               BASE_TERRAIN
    number_of_objects                 1
    if HUGE_MAP 
      number_of_groups                  rnd(7,9)
    else 
      number_of_groups                  rnd(3,4)
    endif

    min_distance_group_placement      2

    if TINY_MAP
      temp_min_distance_group_placement 6
    else
      temp_min_distance_group_placement 32
    endif

    max_distance_to_other_zones       3
    avoid_forest_zone                 1

    if TINY_MAP 
        min_distance_to_map_edge          1
    elseif MEDIUM_MAP 
        min_distance_to_map_edge          1
    elseif LARGE_MAP 
        min_distance_to_map_edge          1
    elseif HUGE_MAP
        min_distance_to_map_edge          1
    endif

    set_gaia_object_only
}

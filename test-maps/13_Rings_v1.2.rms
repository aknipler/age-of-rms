  create_terrain PALM_DESERT { base_terrain BASE_TERRAIN set_avoid_player_start_areas 33 number_of_tiles (5 / 4 * EXT_WOOD_AMOUNT_TILES) number_of_clumps (EXT_WOOD_CLUMPS * 2) } 
else
  create_terrain PALM_DESERT { base_terrain BASE_TERRAIN set_avoid_player_start_areas 33 number_of_tiles (2 * EXT_WOOD_AMOUNT_TILES) number_of_clumps (EXT_WOOD_CLUMPS * 3) } 
endif



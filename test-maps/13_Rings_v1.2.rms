#const NEUTRAL_LANDS_ID 12
#const O_PLAYER_TOTAL_FOREST_TILES 140
#const O_PLAYER_FOREST_CLUMPS 6
#const POND_SIZE rnd(20,40)
#const EXT_WOOD_AMOUNT_TILES 830
#const EXT_WOOD_CLUMPS 21

start_random
percent_chance 9 #const POND_CLUMPS 0
percent_chance 18 #const POND_CLUMPS 1
percent_chance 23 #const POND_CLUMPS 2
percent_chance 23 #const POND_CLUMPS 3
percent_chance 18 #const POND_CLUMPS 4
percent_chance 9 #const POND_CLUMPS 5
end_random

/* terrains */
#const TEMP_TERRAIN 68 
#const TEMP_TERRAIN2 19
#const PLAYER_TEMP_TERR 16
#const MUD 76
#const INSIDE_PL_TERRAIN 3
#const OUTSIDE_PL_TERRAIN 11
#const EXTERNAL_TERRAIN 14
#const BASE_TERRAIN 6
#const INSIDE_NEUTRAL_LAND_TERRAIN 42
#const OUTSIDE_NEUTRAL_LAND_TERRAIN 14
#const OUTSIDE_NEUTRAL_LAND_TERRAIN_MASK 6
#const LOWER_HILLTOPS 41 /* dlc svannah */
#const BROWN_WATER 96
#const INSIDE_GOLD_AREA_TERRAIN 45
#const INSIDE_GOLD_AREA_TERRAIN_MASK 6
#const INSIDE_GOLD_AREA_TERRAIN_MASK2 14
#const INSIDE_FOREST_AREA_TERRAIN 5
#const INSIDE_FOREST_AREA_TERRAIN_MASK 6
#const FOREST_TERRAIN 13
#const EXT_POND_TERRAIN 96

/* objects */
#const MAKE_FOREST_TERRAIN 1639
#const BUSH_A 302
#const BUSH_B 1053
#const FOREST_STRAGGLERS 351


/* Make it so that the forests can't be quickly removed by players using building foundations */
effect_percent SET_ATTRIBUTE MAKE_FOREST_TERRAIN ATTR_RADIUS_1 50 /* make it a 1x1 object */
effect_percent SET_ATTRIBUTE MAKE_FOREST_TERRAIN ATTR_RADIUS_2 50 /* make it a 1x1 object */
effect_amount SET_ATTRIBUTE MAKE_FOREST_TERRAIN ATTR_FOUNDATION_TERRAIN 13 /* palm_desert */


/* outside neutral land options */
start_random 
  percent_chance 33 #define OWAT 
  percent_chance 34 #define OWOOD 
  percent_chance 33 #define OFOOD 
end_random

if OWAT 
  start_random 
    percent_chance 50 #define OWOOD 
    percent_chance 50 #define OFOOD 
  end_random
elseif OWOOD 
  start_random 
    percent_chance 50 #define OWAT 
    percent_chance 50 #define OFOOD
  end_random
elseif OFOOD 
  start_random 
    percent_chance 50 #define OWAT 
    percent_chance 50 #define OWOOD
  end_random
endif 


/* put ponds in the inside forests  */
/* #define INSIDE_FOREST_PONDS */

/* Make it so that the flags disappear at the start of the game */
effect_amount SET_ATTRIBUTE ONGRID_PLACEHOLDER2 ATTR_HITPOINTS 0



<PLAYER_SETUP>
direct_placement
behavior_version 1


if TINY_MAP
    #const INSIDE_RING_BOUNDS 24
elseif HUGE_MAP
    #const INSIDE_RING_BOUNDS 36
    #const OUTSIDE_RING_BOUNDS 15
endif






<LAND_GENERATION>

base_terrain BASE_TERRAIN


/* fill out center */

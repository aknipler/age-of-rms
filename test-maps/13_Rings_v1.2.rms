/* Created by Captain Kniples the Fourth */
/* For AUS/NZ TG tournament 2nd half of 2025 */
/* Created 2025 July */
/* This is a 4v4 map only */




#const ONGRID_PLACEHOLDER 1613


/* math constants */
#const INSIDE_RING_ORIGIN_DIST 16
#const OUTSIDE_RING_ORIGIN_DIST 22
#const OUTSIDE_RING_POCK_ORIGIN_DIST 26
#const OUTSIDE_PLAYER_LAND_TILES 1400
#const OUTSIDE_PL_LAND_BORDER 9
#const INSIDE_NEUTRAL_LAND_TILES 950

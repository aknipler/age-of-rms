/* Make it so that the forests can't be quickly removed by players using building foundations */
effect_percent SET_ATTRIBUTE MAKE_MANGROVEFOREST_TERRAIN ATTR_RADIUS_1 50 /* make it a 1x1 object */
effect_percent SET_ATTRIBUTE MAKE_MANGROVEFOREST_TERRAIN ATTR_RADIUS_2 50 /* make it a 1x1 object */
effect_amount SET_ATTRIBUTE MAKE_MANGROVEFOREST_TERRAIN ATTR_FOUNDATION_TERRAIN 55 /* mangrove forest */

effect_percent SET_ATTRIBUTE MAKE_DIRT3_TERRAIN ATTR_RADIUS_1 50 /* make it a 1x1 object */
effect_percent SET_ATTRIBUTE MAKE_DIRT3_TERRAIN ATTR_RADIUS_2 50 /* make it a 1x1 object */
effect_amount SET_ATTRIBUTE MAKE_DIRT3_TERRAIN ATTR_FOUNDATION_TERRAIN 3 /* DIRT3 */

effect_percent SET_ATTRIBUTE MAKE_FOREST_TERRAIN ATTR_RADIUS_1 50 /* make it a 1x1 object */
effect_percent SET_ATTRIBUTE MAKE_FOREST_TERRAIN ATTR_RADIUS_2 50 /* make it a 1x1 object */
effect_amount SET_ATTRIBUTE MAKE_FOREST_TERRAIN ATTR_FOUNDATION_TERRAIN 10 /* forest */

/* Make it so that fence rubble does not disappear */

 create_actor_area 50  50 3000 50 
 create_actor_area 118 50 3000 50 
 /* avoid lower lands */
 create_actor_area 50  151 3010 50 
 create_actor_area 118 151 3010 50 

 create_actor_area 42 126 3100 42
 create_actor_area 126 126 3101 42
endif 


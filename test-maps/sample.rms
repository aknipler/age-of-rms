/* Age of RMS sample map.
   Exercises every token category the aoe2-rms Monarch tokenizer handles
   (Phase 1.4) — comments, section headers, directives, control keywords,
   commands, attributes, ALL_CAPS constants, numbers. Not a complete or
   balanced playable map; open it in the Code tab to visually check
   highlighting. */

#const NUM_PLAYERS 2
#define FFA_MODE

<PLAYER_SETUP>

if HUGE_MAP
    #define BIG_LANDS
elseif CONFIG2
    #undefine BIG_LANDS
endif

create_player_lands
{
    terrain_type GRASS
    land_percent 50
    base_size 15
    zone 1
}

<LAND_GENERATION>

base_terrain WATER

create_land
{
    terrain_type FOREST
    land_percent 10
    number_of_clumps 6
    set_scale_by_groups
}

<ELEVATION_GENERATION>

create_elevation
{
    base_size 6
    number_of_clumps 20
}

<TERRAIN_GENERATION>

start_random
    percent_chance 60 create_terrain
    {
        terrain_type DIRT3
        number_of_clumps 10
        number_of_tiles 200
    }
    percent_chance 40 create_terrain
    {
        terrain_type LEAVES
        number_of_clumps 8
        number_of_tiles 150
    }
end_random

<CLIFF_GENERATION>

<CONNECTION_GENERATION>

create_connect_all_players_land
{
    terrain_type DIRT3
}

<OBJECTS_GENERATION>

create_object GOLD
{
    number_of_objects 4
    terrain_to_place_on DESERT
    min_distance_group_placement 3
    set_gaia_object_only
}

create_object STONE
{
    number_of_objects 3
    terrain_to_place_on GRASS
}

/* Created by Captain Kniples the Fourth */
/* 3 Villager version made for Thalassocracy 2 */
/* First created 2025 July, last update 22 Aug 2025 */
/* 
Changelog:
21-08-2025
- made the 3 villager version
22-08-2025 (For Thalassocracy Cup)
- increased player land percent from 24->25
- increased player total forest tiles from 100->110
- increased external forest tiles from 460->470 
24-8-2025
- there are 2 create shore_fish statements, one that is player driven to get shore fish on both sides of the center strait. 
  However this leads to instances where you have two shorefish right next to each other. Attempted to reduce the likelihood of this
  by giving the player driven shore_fish min_dist_placement of 1 and also reducing the number of them from 22->18.
- made the herdables have a random chance of being goat, sheep or pig
- fixed an issue where the lands would sometimes be connected. It was due to the base size being too big, so when they are directly
  above or side-by-side the corners would overlap. Base size 11->10
- seemed to be a bias for player resources to generate in a south westerly direction. Addressed this by increasing the actor areas
  for each resource, making them more spaced. 
** Addressing the issue of a transport ship easily stealing an opponents sheep **
- used placeholders to make the transport ships spawn closer to the back of the islands
- made the scouts always spawn closest to the center of the map
*/


#define 3_VILL_START
/* #define 9_VILL_START */

#const ONGRID_PLACEHOLDER 1613
#const ONGRID_PLACEHOLDER2 278 /* dead fish trap */
/* #const ONGRID_PLACEHOLDER_ALL 1543 */
/* #const ONGRID_PLACEHOLDER_LAND 1544 */
#const ONGRID_PLACEHOLDER_AMPHIBIOUS 1545


/* math constants */
#const INSIDE_RING_ORIGIN_DIST 16
#const ISLAND_BORDERS 3
#const PLAYER_FOREST_CLUMPS 3
#const PLAYER_TOTAL_FOREST_TILES 110
#const PL_BORDERS 12

/* terrains */
#const TEMP_TERRAIN 68 
#const TEMP_TERRAIN2 19
#const PLAYER_TEMP_TERR 74
#const MUD 76
#const PL_TERRAIN 34 /* snow grass */
#const NEUTRAL_TERRAIN 32 /* snow */
#const NEUTRAL_TERRAIN_MASK 0
#const TERRAIN_MASK 32
#const BASE_TERRAIN 1

/* objects */
#const MAKE_UNDERBRUSH_SNOW_TERRAIN 1639
#const MAKE_SNOW_TERRAIN 1640


start_random
percent_chance 33 #const HERDABLE DLC_GOAT
percent_chance 34 #const HERDABLE SHEEP 
percent_chance 33 #const HERDABLE DLC_PIG 
end_random

/* change DLC_ZEBRA to penguins */
effect_amount SET_ATTRIBUTE DLC_ZEBRA ATTR_NAME_ID 5734
effect_amount SET_ATTRIBUTE DLC_ZEBRA ATTR_ICON_ID 157
effect_amount SET_ATTRIBUTE DLC_ZEBRA ATTR_STANDING_GRAPHIC 8259 
effect_amount SET_ATTRIBUTE DLC_ZEBRA ATTR_DYING_GRAPHIC 8258 
effect_amount SET_ATTRIBUTE DLC_ZEBRA ATTR_UNDEAD_GRAPHIC 8258 
effect_amount SET_ATTRIBUTE DLC_ZEBRA ATTR_WALKING_GRAPHIC 8261 
effect_amount SET_ATTRIBUTE DLC_ZEBRA ATTR_RUNNING_GRAPHIC 8261 
effect_amount SET_ATTRIBUTE DLC_ZEBRA ATTR_STANDING_GRAPHIC 8259 
effect_amount SET_ATTRIBUTE DLC_ZEBRA ATTR_ATTACK_GRAPHIC 8257
effect_amount SET_ATTRIBUTE DLC_ZEBRA ATTR_UPGRADE_GRAPHIC 8257
effect_amount SET_ATTRIBUTE DLC_ZEBRA ATTR_DEAD_ID 641 
effect_amount SET_ATTRIBUTE DLC_ZEBRA ATTR_STORAGE_VALUE 1

/* Make it so that the forests can't be quickly removed by players using building foundations */
effect_percent SET_ATTRIBUTE MAKE_UNDERBRUSH_SNOW_TERRAIN ATTR_RADIUS_1 50 /* make it a 1x1 object */
effect_percent SET_ATTRIBUTE MAKE_UNDERBRUSH_SNOW_TERRAIN ATTR_RADIUS_2 50 /* make it a 1x1 object */
effect_amount SET_ATTRIBUTE MAKE_UNDERBRUSH_SNOW_TERRAIN ATTR_FOUNDATION_TERRAIN 72 /* underbrush snow */
effect_amount SET_ATTRIBUTE MAKE_UNDERBRUSH_SNOW_TERRAIN ATTR_FOG_FLAG 0 /* underbrush snow */
/* effect_amount SET_ATTRIBUTE MAKE_UNDERBRUSH_SNOW_TERRAIN ATTR_STANDING_GRAPHIC 11202 So that if seen in a start of game revealer, the artifact it leaves is much harder to see */  

effect_percent SET_ATTRIBUTE MAKE_SNOW_TERRAIN ATTR_RADIUS_1 50 /* make it a 1x1 object */
effect_percent SET_ATTRIBUTE MAKE_SNOW_TERRAIN ATTR_RADIUS_2 50 /* make it a 1x1 object */
effect_amount SET_ATTRIBUTE MAKE_SNOW_TERRAIN ATTR_FOUNDATION_TERRAIN 32 /* snow */
effect_amount SET_ATTRIBUTE MAKE_SNOW_TERRAIN ATTR_STANDING_GRAPHIC 12263  /* So that if seen in a start of game revealer, the artifact it leaves is much harder to see */
effect_amount SET_ATTRIBUTE MAKE_SNOW_TERRAIN ATTR_FOG_FLAG 0  /* So that if seen in a start of game revealer, the artifact it leaves is much harder to see */



/* Make it so that the flags disappear at the start of the game */
effect_amount SET_ATTRIBUTE ONGRID_PLACEHOLDER2 ATTR_HITPOINTS 0


#const HERDABLE_A 1245 /* Pig */
#const HERDABLE_B 594 /* Sheep */

if 9_VILL_START
  /* make the herdable under the TC die and only have 70 food */
  /* note that you should NOT place this herdable type for gaia anywhere else */
  effect_amount GAIA_ADD_ATTRIBUTE HERDABLE_A ATTR_STORAGE_VALUE -30	
  effect_amount GAIA_SET_ATTRIBUTE HERDABLE_A ATTR_HITPOINTS 0

  effect_amount MOD_RESOURCE AMOUNT_STARTING_WOOD ATTR_ADD -30
  effect_amount MOD_RESOURCE AMOUNT_STARTING_FOOD ATTR_ADD -90

  #const LAZY_MALE 1285 /* FE Flag */
  effect_amount SET_ATTRIBUTE LAZY_MALE ATTR_DEAD_ID 83
  effect_amount SET_ATTRIBUTE LAZY_MALE ATTR_HITPOINTS 0

  #const LAZY_FEMALE 851 /* ES Flag */
  effect_amount SET_ATTRIBUTE LAZY_FEMALE ATTR_DEAD_ID 293
  effect_amount SET_ATTRIBUTE LAZY_FEMALE ATTR_HITPOINTS 0
endif

<PLAYER_SETUP>
random_placement
behavior_version 1


if TINY_MAP
    #const INSIDE_RING_BOUNDS 24
elseif HUGE_MAP
    #const INSIDE_RING_BOUNDS 36
    #const OUTSIDE_RING_BOUNDS 15
endif






<LAND_GENERATION>

base_terrain BASE_TERRAIN

create_player_lands { terrain_type PLAYER_TEMP_TERR land_percent 25 circle_radius 16 1 base_size 10 clumping_factor 20 other_zone_avoidance_distance 3 left_border PL_BORDERS right_border PL_BORDERS top_border PL_BORDERS bottom_border PL_BORDERS }

/* neutral islands */
create_land { terrain_type NEUTRAL_TERRAIN land_percent 6 base_size rnd(7,9) clumping_factor rnd(13,24) other_zone_avoidance_distance 10  zone 1 land_id 100 land_position 9 9 }
create_land { terrain_type NEUTRAL_TERRAIN land_percent 6 base_size rnd(7,9) clumping_factor rnd(13,24) other_zone_avoidance_distance 10  zone 2 land_id 100 land_position 9 91 }
create_land { terrain_type NEUTRAL_TERRAIN land_percent 6 base_size rnd(7,9) clumping_factor rnd(13,24) other_zone_avoidance_distance 10  zone 3 land_id 100 land_position 91 9 }
create_land { terrain_type NEUTRAL_TERRAIN land_percent 6 base_size rnd(7,9) clumping_factor rnd(13,24) other_zone_avoidance_distance 10  zone 4 land_id 100 land_position 91 91 }



<ELEVATION_GENERATION>

create_elevation 1
{
  base_terrain          PLAYER_TEMP_TERR 
  number_of_tiles       40      
  number_of_clumps      3
  spacing               0         
  enable_balanced_elevation   
  set_scale_by_groups  
}


create_elevation 1
{
  base_terrain          NEUTRAL_TERRAIN 
  number_of_tiles       250      
  number_of_clumps      15         
  enable_balanced_elevation    
  set_scale_by_groups        
}




<TERRAIN_GENERATION>

/* fix small patches */
create_terrain TEMP_TERRAIN { base_terrain BASE_TERRAIN land_percent 5 number_of_clumps 6 set_scale_by_groups spacing_to_other_terrain_types 3 }
create_terrain NEUTRAL_TERRAIN { base_terrain TEMP_TERRAIN land_percent 100 number_of_clumps 4056 }


create_terrain SNOW_FOREST { base_terrain TEMP_TERRAIN number_of_tiles PLAYER_TOTAL_FOREST_TILES number_of_clumps PLAYER_FOREST_CLUMPS spacing_to_other_terrain_types 3 set_avoid_player_start_areas 13 } 
create_terrain PL_TERRAIN { base_terrain TEMP_TERRAIN land_percent 100 number_of_clumps beach_terrain ICYSHORE 4056 } 
create_terrain PL_TERRAIN { base_terrain TEMP_TERRAIN land_percent 100 number_of_clumps beach_terrain ICYSHORE 4056 } 
create_terrain PL_TERRAIN { base_terrain TEMP_TERRAIN land_percent 100 number_of_clumps beach_terrain ICYSHORE 4056 } 



/* masking */
create_terrain NEUTRAL_TERRAIN_MASK { base_terrain NEUTRAL_TERRAIN land_percent 31 number_of_clumps 4056 terrain_mask 1 } 
create_terrain TERRAIN_MASK { base_terrain PL_TERRAIN land_percent 2 number_of_clumps 6 terrain_mask 1 } 



/* neutral forests */
create_terrain SNOW_FOREST { base_terrain NEUTRAL_TERRAIN number_of_tiles 470 number_of_clumps 30 spacing_to_other_terrain_types 2 set_scale_by_groups } 



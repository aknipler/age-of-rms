<ELEVATION_GENERATION>

create_elevation 3
{
    enable_balanced_elevation
    base_terrain LAND_TEMP

    if TINY_MAP
        number_of_tiles 300
        number_of_clumps 18
    elseif SMALL_MAP
        number_of_tiles 580
        number_of_clumps 19
    elseif MEDIUM_MAP
        number_of_tiles 740
        number_of_clumps 24
    elseif LARGE_MAP
        number_of_tiles 1122
        number_of_clumps 36
    elseif HUGE_MAP
        number_of_tiles 1333
        number_of_clumps 44
    elseif GIGANTIC_MAP
        number_of_tiles 1620
        number_of_clumps 51
    elseif LUDIKRIS_MAP
        number_of_tiles 6080
        number_of_clumps 190
    endif
}

create_elevation 3
{
    enable_balanced_elevation
    base_terrain YIN

    if TINY_MAP
        number_of_tiles 9
        number_of_clumps rnd(2,3)
    endif
}
create_elevation 3
{
    enable_balanced_elevation
    base_terrain YANG

    if TINY_MAP
        number_of_tiles 9
        number_of_clumps rnd(2,3)
    endif
}


start_random
    /* percent_chance 50 #define FLIP_P1P2 */
end_random

create_land
{
    terrain_type YIN
    number_of_tiles 1244
    base_size 5
    zone 33
    if FLIP_P1P2
        assign_to AT_PLAYER 1 0 0
    else
        assign_to AT_PLAYER 2 0 0
    endif

    land_position 66 12
    left_border 60
    top_border -20
    right_border -20
    bottom_border 60
    other_zone_avoidance_distance 6

    base_elevation 1
}
create_land
{
    terrain_type YANG
    number_of_tiles 1244
    base_size 5
    zone 33
    if FLIP_P1P2
        assign_to AT_PLAYER 2 0 0
    else
        assign_to AT_PLAYER 1 0 0
    endif

    land_position 88 34
    left_border 60
    top_border -20
    right_border -20
    bottom_border 60
    other_zone_avoidance_distance 6

    base_elevation 1
}


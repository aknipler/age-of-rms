/* objects */
#const ONGRID_PLACEHOLDER 1613
#const ONGRID_PLACEHOLDER_1 278
#const MAKE_WATER_TERRAIN 1641
#const MAKE_QUICKSAND_TERRAIN 1640
#const MAKE_FOREST_TERRAIN 1639
#const HARBOUR 1189
#const TEMP 278
#const SABOTEUR 706

start_random
  percent_chance 50 #define THEME1
  percent_chance 50 #define THEME2
end_random

if THEME1
  #const HERDABLE 594
  #const HUNTABLE 65
  #const LURABLE  48
  #const THEMED_TREE 351 /* palmtree */
  #const THEMED_TREE_NOMADLAND 349 /* oaktree */
elseif THEME2
  #const HERDABLE 594
  #const HUNTABLE 65
  #const LURABLE  48
  #const THEMED_TREE 351 /* palmtree */
  #const THEMED_TREE_NOMADLAND 349 /* oaktree */
endif

/* explody bois */
effect_amount SET_ATTRIBUTE SABOTEUR ATTR_HITPOINTS 0
effect_percent SET_ATTRIBUTE SABOTEUR ATTR_BLAST_RADIUS 60
effect_amount SET_ATTRIBUTE SABOTEUR ATTR_BLAST_LEVEL 2
effect_amount SET_ATTRIBUTE SABOTEUR ATTR_MAX_RANGE 2
effect_amount SET_ATTRIBUTE SABOTEUR ATTR_ATTACK rnd(2950,2960) /* class 11 so 11*256 = 2816. Then we add how much damage we want on top of that */

/* effect_amount SET_ATTRIBUTE SABOTEUR ATTR_DEAD_ID 857 */

/* make it so yurts can be placed using an on grid placeholder */
effect_percent SET_ATTRIBUTE ONGRID_PLACEHOLDER_1 ATTR_RADIUS_1 100 /* make it a 2x2 object */
effect_percent SET_ATTRIBUTE ONGRID_PLACEHOLDER_1 ATTR_RADIUS_2 100 /* make it a 2x2 object */

/* Make it so that the flags disappear at the start of the game */
effect_amount SET_ATTRIBUTE MAKE_WATER_TERRAIN ATTR_HITPOINTS 0
/* so that forest terrain cant be put on water and will avoid it properly */
/* effect_amount SET_ATTRIBUTE MAKE_FOREST_TERRAIN ATTR_TERRAIN_ID 4 */
/*
/* Make it so that the forests can't be quickly removed by players using building foundations */
effect_percent SET_ATTRIBUTE MAKE_WATER_TERRAIN ATTR_RADIUS_1 50 /* make it a 1x1 object */
effect_percent SET_ATTRIBUTE MAKE_WATER_TERRAIN ATTR_RADIUS_2 50 /* make it a 1x1 object */
effect_amount SET_ATTRIBUTE MAKE_WATER_TERRAIN ATTR_FOUNDATION_TERRAIN 1 /* water */ 
*/ 
effect_percent SET_ATTRIBUTE MAKE_QUICKSAND_TERRAIN ATTR_RADIUS_1 50 /* make it a 1x1 object */
effect_percent SET_ATTRIBUTE MAKE_QUICKSAND_TERRAIN ATTR_RADIUS_2 50 /* make it a 1x1 object */
effect_amount SET_ATTRIBUTE MAKE_QUICKSAND_TERRAIN ATTR_FOUNDATION_TERRAIN 102 /* dlc quicksand */

effect_percent SET_ATTRIBUTE MAKE_FOREST_TERRAIN ATTR_RADIUS_1 50 /* make it a 1x1 object */
effect_percent SET_ATTRIBUTE MAKE_FOREST_TERRAIN ATTR_RADIUS_2 50 /* make it a 1x1 object */
effect_amount SET_ATTRIBUTE MAKE_FOREST_TERRAIN ATTR_FOUNDATION_TERRAIN 10 /* forest */



/* so that buildings can be built on beach */
effect_amount SET_ATTRIBUTE MAKE_QUICKSAND_TERRAIN ATTR_TERRAIN_ID 10
effect_amount SET_ATTRIBUTE YURT2 ATTR_TERRAIN_ID 10
effect_amount SET_ATTRIBUTE YURT3 ATTR_TERRAIN_ID 10
effect_amount SET_ATTRIBUTE YURT4 ATTR_TERRAIN_ID 10
/* effect_amount SET_ATTRIBUTE BUILDING_CLASS ATTR_TERRAIN_ID 10
effect_amount SET_ATTRIBUTE FARM_CLASS ATTR_TERRAIN_ID 10
effect_amount SET_ATTRIBUTE TOWER_CLASS ATTR_TERRAIN_ID 10

#const HARBOR 1189
effect_amount SET_ATTRIBUTE DOCK ATTR_TERRAIN_ID 6
effect_amount SET_ATTRIBUTE DOCK_F ATTR_TERRAIN_ID 6
effect_amount SET_ATTRIBUTE DOCK_C ATTR_TERRAIN_ID 6
effect_amount SET_ATTRIBUTE DOCK_I ATTR_TERRAIN_ID 6
effect_amount SET_ATTRIBUTE HARBOR ATTR_TERRAIN_ID 6

effect_amount SET_ATTRIBUTE FISH_TRAP ATTR_TERRAIN_ID 13 */

/* Make it so that fence rubble does not disappear */
effect_amount GAIA_SET_ATTRIBUTE FENCE_RUBBLE ATTR_STORAGE_VALUE 30000

<PLAYER_SETUP>
direct_placement 
behavior_version 1
ai_info_map_type CUSTOM 0 0 0

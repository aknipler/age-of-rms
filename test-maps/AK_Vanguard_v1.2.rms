/* Created by Captain Kniples the Fourth */
/* For AUS/NZ TG tournament 2nd half of 2025 */
/* Created 2025 July */
/* This is a 4v4 map only */

/* 
Changelog:
v1: completed
v1.1 (04 09 2025):
- increased external wood so that total wood on map went from ~213k -> ~506k
- reduced chickens in middle from ~6-7 groups of 7 to ~3-4 groups of 5-6

*/


#const ONGRID_PLACEHOLDER 1613


/* math constants */
#const PL_LAND_TILES 22000
#const LANDS_ZONE_AVOIDANCE_DIST 3
#const PL_BASE_SIZE 10
#const PL_LANDS_CLUMPING_FAC 15
#const O_PL_ZONE_AVOID_DIST 9
#const PL_TOTAL_FOREST_TILES 60
#const PL_FOREST_CLUMPS 3
#const PL_FOREST_MIN_DIST 13
#const PL_FOREST_MAX_DIST 17
#const EXT_WOOD_LAND_PERCENT 7
#const EXT_WOOD_CLUMPS 18
#const TEAM_RES_AREA_NO_OF_TILES 850
#const TEAM_RES_AREA_BORDERS 15
#const TEAM_RES_AREA_BASE_SIZE 10

#const ACT_AREA_MIDDLE_MED 6756
#const ACT_AREA_MIDDLE_LARGE 6757
#const ACT_AREA_NOBUILD_AROUND_TEAM_RES 42

/* terrains */
#const TEMP_DIVIDING_LINE_TERRAIN 47
start_random
  percent_chance 50 #define SEASON_BOG
  percent_chance 25 #define SEASON_ICE
  percent_chance 25 #define SEASON_ROCKY
end_random

if SEASON_BOG
  #const DIVIDING_LINE_TERRAIN 101 /* dlc_bogland */
  #const TEAM_RES_AREA_TERRAIN_MASK 32 /* snow */
elseif SEASON_ICE
  #const DIVIDING_LINE_TERRAIN 35 /* ice */
  #const TEAM_RES_AREA_TERRAIN_MASK 32 /* snow */
elseif SEASON_ROCKY
  #const DIVIDING_LINE_TERRAIN 40 /* dlc_rock */
  #const TEAM_RES_AREA_TERRAIN_MASK 32 /* snow */
endif
#const DIVIDING_LINE_TERRAIN_MASK 32 /* snow */
#const TEMP_TEAM_RES_AREA_TERRAIN 42
#const TEAM_RES_AREA_TERRAIN 74 /* snow_heavy */

#const TEMP_TERRAIN 68 
#const TEMP_TERRAIN2 19
#const PLAYER_TEMP_TERR 16
#const MUD 76
#const PL_TERRAIN 34 /* snow grass */
#const FOREST_TERRAIN 21
#const TEMP_BASE_TERRAIN 18 
#const BASE_TERRAIN 32
#const BASE_TERRAIN_MASK 0
#const BASE_TERRAIN_MASK2 100
#const BASE_TERRAIN_MASK3 5
#const BASE_TERRAIN_MASK4 9
#const BASE_TERRAIN_MASK5 76
#const TEMP_PL_TERRAIN 3
#const TERR_TEMP_PL_FORESTS 72

/* objects */
#const MAKE_FOREST_TERRAIN 1639
#const STRAGGLER_TREES 413 /* 1249 */
#const ONGRID_PLACEHOLDER_LAND 1544
#const HUNTABLE 1896 /* argali */
#const HERDABLE 1060 /* goat */
#const LURABLE 48 /* boar */
#const BERRIES 1059 /* orange bush */

#const ESCALATION_REVEALER 837

#const SNOW_MOUNT_A rnd(1045,1047)
#const SNOW_MOUNT_B rnd(1045,1047)

/* stop placehllder going on ice */
effect_amount SET_ATTRIBUTE ONGRID_PLACEHOLDER_LAND ATTR_TERRAIN_ID 4

/* view gold areas */
/* effect_amount SET_ATTRIBUTE ESCALATION_REVEALER ATTR_DEAD_ID -1 */
/* effect_amount SET_ATTRIBUTE ESCALATION_REVEALER ATTR_TERRAIN_ID 0 */
effect_amount SET_ATTRIBUTE ESCALATION_REVEALER ATTR_LINE_OF_SIGHT 4

/* Make it so that the forests can't be quickly removed by players using building foundations */
effect_percent SET_ATTRIBUTE MAKE_FOREST_TERRAIN ATTR_RADIUS_1 50 /* make it a 1x1 object */
effect_percent SET_ATTRIBUTE MAKE_FOREST_TERRAIN ATTR_RADIUS_2 50 /* make it a 1x1 object */
effect_amount SET_ATTRIBUTE MAKE_FOREST_TERRAIN ATTR_FOUNDATION_TERRAIN 13 /* palm_desert */


/* Make it so that the flags disappear at the start of the game */
effect_amount SET_ATTRIBUTE ONGRID_PLACEHOLDER2 ATTR_HITPOINTS 0



<PLAYER_SETUP>
direct_placement
behavior_version 1







<LAND_GENERATION>

base_terrain DIVIDING_LINE_TERRAIN


/* fill out center */
/* create_land { terrain_type BASE_TERRAIN land_percent 100 clumping_factor PL_LANDS_CLUMPING_FAC land_position 90 10 top_border 5 bottom_border 5 right_border 5 left_border 5 }
create_land { terrain_type BASE_TERRAIN land_percent 100 clumping_factor PL_LANDS_CLUMPING_FAC land_position 10 90 top_border 5 bottom_border 5 right_border 5 left_border 5 } */


/* outside ring */
start_random
  percent_chance 50 #define CONFIG_FIFTY_A
  percent_chance 50 #define CONFIG_FIFTY_B
end_random
if CONFIG_FIFTY_A
  start_random
    percent_chance 25 #define CONFIG_1
    percent_chance 25 #define CONFIG_2
    percent_chance 25 #define CONFIG_3
    percent_chance 25 #define CONFIG_4

<CONNECTION_GENERATION>

create_connect_to_nonplayer_land
{
    replace_terrain PALM_DESERT DLC_DRYGRASS
    replace_terrain ICE DLC_DRYGRASS
    /* replace_terrain DLC_DRYGRASS DLC_DRYGRASS */
    replace_terrain BEACH DLC_WETBEACH

    terrain_cost DIRT 15 
    terrain_cost BEACH 1 
    terrain_cost SHALLOW 1 
    terrain_cost PALM_DESERT 32 
    terrain_cost GRASS 35 
    terrain_cost DLC_DRYGRASS 35 
    terrain_cost DESERT 0 
    terrain_cost ICE 6

    if 6_PLAYER_GAME
        terrain_size PALM_DESERT 4 0 
        terrain_size DLC_DRYGRASS 3 0 
    else 
        terrain_size PALM_DESERT 3 0 
    endif
}

<OBJECTS_GENERATION>
/* 
List of attributes (can also be found on the guide, but its more detailed):
 number_of_objects
 number_of_groups
 set_place_for_every_player
 set_scaling_to_map_size
 set_scaling_to_player_number
 min_distance_to_players
 max_distance_to_players
 set_tight_grouping
 set_loose_grouping
 group_placement_radius
 group_variance
 set_gaia_object_only
 min_distance_group_placement
 temp_min_distance_group_placement
 max_distance_to_other_zones
 terrain_to_place_on
 resource_delta increase or decrease the amount of res that an object has. +100 to deer will m ake deer have an extra 100 food, -11 will make it have 100 less food
 place_on_specific_land_id only works if there is separation bw the player and the land_id
*/


create_elevation 4
{
    base_terrain DESERT 
    if TINY_MAP 
        if ELEVATION_FEW number_of_tiles 999 number_of_clumps 23 elseif ELEVATION_MODERATE number_of_tiles 1410 number_of_clumps 33 elseif ELEVATION_LOTS number_of_tiles 1620 number_of_clumps 42 endif  
    else
        if ELEVATION_FEW number_of_tiles 2720 number_of_clumps 29 elseif ELEVATION_MODERATE number_of_tiles 3720 number_of_clumps 38 elseif ELEVATION_LOTS number_of_tiles 4580 number_of_clumps 48 endif 
    endif
    spacing 0 set_scale_by_groups enable_balanced_elevation
}


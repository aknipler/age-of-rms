/* 
Feedback:
- Placing TCs on edge of map can be hard due to hills, could there be a way to make it so hills stay ~3-4 tiles away from the edge forests?


*/



/* ***** OPTIONS TO CHANGE ASPECTS OF THE MAP ***** */
/* ***** 4_PONDS takes preference, cannot have both 6 and 4 ponds on at same time. 
         Need to make sure that OUTSIDE_PONDS is on as well.                        ***** */
#define FISH_IN_OUTSIDE_PONDS
#define OUTSIDE_PONDS
#define 4_PONDS
/* #define 6_PONDS */
/* #define FOREST_RIVERS */
/* #define CUSTOM_OSTRICH_BALANCE */




/* *** defining constants *** */
/* terrains */
#const WATER_GREEN 95
#const LEAVES2 71
#const TEMP_TERRAIN 68 
#const TEMP_TERRAIN2 62
#const TEMP_TERRAIN3 12

/* objects */
#const WELL 1567
#const ONGRID_PLACEHOLDER 1613
#const ONGRID_PLACEHOLDER_1 278
#const FISH_PLACEHOLDER 647 

#const BUSH_A 302
#const BUSH_B 1053
#const BUSH_FOREST 89
#const TREE_AUTUMN 1248
#const FOREST_AUTUMN 104
#const TREE_ITALIAN 1348
#const OLIVETREE 1349

/* ************************************************************************************************ PLAYER SETUP ************************************************************************************************ */

<PLAYER_SETUP>
direct_placement
behavior_version 1

#const TRIBUTE_INEFFICIENCY 46 
effect_percent MOD_RESOURCE TRIBUTE_INEFFICIENCY ATTR_SET 50

/* so that buildings can be built on beach */
effect_amount SET_ATTRIBUTE BUILDING_CLASS ATTR_TERRAIN_ID 10
effect_amount SET_ATTRIBUTE FARM_CLASS ATTR_TERRAIN_ID 10
effect_amount SET_ATTRIBUTE TOWER_CLASS ATTR_TERRAIN_ID 10

#const HARBOR 1189
effect_amount SET_ATTRIBUTE DOCK ATTR_TERRAIN_ID 6
effect_amount SET_ATTRIBUTE DOCK_F ATTR_TERRAIN_ID 6
effect_amount SET_ATTRIBUTE DOCK_C ATTR_TERRAIN_ID 6
effect_amount SET_ATTRIBUTE DOCK_I ATTR_TERRAIN_ID 6
effect_amount SET_ATTRIBUTE HARBOR ATTR_TERRAIN_ID 6

effect_amount SET_ATTRIBUTE FISH_TRAP ATTR_TERRAIN_ID 13


/* Make it so emus (ostriches) have less food  */
if CUSTOM_OSTRICH_BALANCE
    effect_amount SET_ATTRIBUTE DLC_OSTRICH ATTR_STORAGE_VALUE 80
endif

/* Make it so trees dont automatically spawn, so that tree theme can be better controlled */
effect_amount GAIA_SET_ATTRIBUTE TREE_AUTUMN ATTR_TERRAIN_ID 3
effect_amount GAIA_SET_ATTRIBUTE PALMTREE ATTR_TERRAIN_ID 3

#const FENCE_RUBBLE 1065
effect_amount GAIA_SET_ATTRIBUTE FENCE_RUBBLE ATTR_STORAGE_VALUE 30000

/* ********************************************************************************************** LAND GENERATION ********************************************************************************************** */

<LAND_GENERATION>

base_terrain DESERT

enable_waves 0



/* Create forests at border */
/* Bottom */
create_land { if FOREST_RIVERS terrain_type SHALLOW border_fuzziness 15 else terrain_type PALM_DESERT  border_fuzziness 5 endif if TINY_MAP top_border 91 elseif MEDIUM_MAP top_border 89 else top_border 84 endif land_percent 100 land_position 99 99 other_zone_avoidance_distance 2 zone 9 }

/* Top */
create_land { if FOREST_RIVERS terrain_type SHALLOW  border_fuzziness 15 else terrain_type PALM_DESERT  border_fuzziness 5 endif if TINY_MAP bottom_border 91 elseif MEDIUM_MAP bottom_border 89 else bottom_border 84 endif land_percent 100 land_position 0 0 other_zone_avoidance_distance 2 zone 9 }




/* Forest at center of team 1 */
create_land
{
    terrain_type DIRT
    land_percent 100
    base_size 2
    bottom_border 42
    top_border 42
    left_border 26
    border_fuzziness 30
    if TINY_MAP
        bottom_border 40
        top_border 40
        left_border 22
        right_border 60
        land_position 32 50
        border_fuzziness 36
    elseif MEDIUM_MAP
        bottom_border 42
        top_border 42
        left_border 26
        right_border 60
        land_position 34 50
    elseif LARGE_MAP
        right_border 58
        land_position 34 49
    elseif HUGE_MAP
        right_border 59
        land_position 35 50
    else 
        right_border 59
        land_position 33 50
    endif
    zone 2
    land_id 1
    base_elevation 1
}

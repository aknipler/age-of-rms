{
    base_terrain TEMP_TERRAIN 
    if TINY_MAP
        if ELEVATION_FEW number_of_tiles 104 number_of_clumps 4 elseif ELEVATION_MODERATE number_of_tiles 130 number_of_clumps 8 elseif ELEVATION_LOTS number_of_tiles 190 number_of_clumps 9 endif
    else
        if ELEVATION_FEW number_of_tiles 180 number_of_clumps 3 elseif ELEVATION_MODERATE number_of_tiles 255 number_of_clumps 4 elseif ELEVATION_LOTS number_of_tiles 410 number_of_clumps 6 endif 
    endif
    spacing 0 enable_balanced_elevation set_scale_by_groups
}
create_elevation 4
{
    base_terrain TEMP_TERRAIN2 
    if TINY_MAP
        if ELEVATION_FEW number_of_tiles 104 number_of_clumps 4 elseif ELEVATION_MODERATE number_of_tiles 130 number_of_clumps 8 elseif ELEVATION_LOTS number_of_tiles 190 number_of_clumps 9 endif 
    else
        if ELEVATION_FEW number_of_tiles 180 number_of_clumps 3 elseif ELEVATION_MODERATE number_of_tiles 255 number_of_clumps 4 elseif ELEVATION_LOTS number_of_tiles 410 number_of_clumps 6 endif 
    endif
    spacing 0 set_scale_by_groups enable_balanced_elevation
}
create_elevation 4
{
    base_terrain FOREST 
    if TINY_MAP number_of_tiles 750 number_of_clumps 36 
    else
    number_of_tiles 1750 number_of_clumps 46 
    endif 
    spacing 0 set_scale_by_groups enable_balanced_elevation
}





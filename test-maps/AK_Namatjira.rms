/* For funsies */
/* Created 2024 08 14 */


/* ******************************************************************************************************
 * This map is based on a real life location, Palm Valley in Namatjira National Park Australia.         *
 ****************************************************************************************************** */

/* The hilltops could probably look better by adding some masking to the very top, adding some variation with masking or something. This is a final polish if time kind of thing */

/* This script has only been tested for 1v1 and 3v3s, do not expect it to work in any other situation. */


/* terrains */
#const GRASS_CLIFFS 16
#const CENTER_TERRAIN 100 /* 6 */ /* DLC_DRYGRASS */
/*  */
#const CENTER_TERRAIN_MASK 6 /* dirt mask */ 
#const CENTER_TERRAIN_MASK2 42 /* dlc_dirt4 mask */ 
#const CENTER_TERRAIN_MASK_INSIDE1 45 /* cracked mask */ 
#const CENTER_TERRAIN_MASK_INSIDE2 41 /* dlc_savannah mask */ 
/* DLC_SAVANNAH */
#const HILLTOP_TERRAIN 102 /* desert gravel */ 
#const HILLTOP_TERRAIN_MASK 14  /* desert */ 
#const HILL_TERRAIN 3 /* this is a temp terrain, dirt3 */ 
#const HILL_TERRAIN_FINAL 41 /* this is what the temp terrain gets turned into, dlc_savannah */ 
#const HILL_TERRAIN_FINAL_MASK 42 /* dlc_dirt4 */ 
#const RIVERBANK_TERRAIN_TEMP 77 /* TEMP_TERRAIN */  
#const RIVERBANK_TERRAIN 11 /* DIRT2 */  
#const RIVERBANK_TERRAIN_MASK 41 /* dlc_savannah */  
#const RIVERBANK_TERRAIN_MASK2 12 /* grass2 */  
#const HILL_TERRAIN_PLACEHOLDER 68 
#const PLACEHOLDER_TERRAIN 8
#const PLACEHOLDER_TERRAIN2 60
#const BASE_LEVEL_TERRAIN 6 /* dirt */ 
#const TEMP_TERRAIN 76
#const REPLACE_A 84
#const REPLACE_B 85
#const REPLACE_C 86
#const REPLACE_D 87
#const REPLACE_E 33
#const REPLACE_F 34
#const REPLACE_TREES 14
#const REPLACE_LUMBER 14
/* #const REPLACE_LUMBER 62 */

/* I set the lumber up, but didn't like it. */
/* objects */
#const LUMBER 1320
#const FISH_PLACEHOLDER 647 
#const cGoldMine 932
#const cStoneMineClass 908
#const ONGRID_PLACEHOLDER 1613
#const TERRAIN_BLOCKER 1613 /* On-Grid Object - doesn't allow objects to generate on the same tile, must not be used as player object */



/* Number of player starting forests */
start_random
  percent_chance 55 #define CONFIG_TWO_PLAYER_FORESTS
  percent_chance 45 #define CONFIG_THREE_PLAYER_FORESTS
end_random


/* Number of players, for player starting forest generations */
if 1_PLAYER_GAME
  #define ONE_GENERATION
elseif 2_PLAYER_GAME
  #define ONE_GENERATION
  #define TWO_GENERATION
elseif 3_PLAYER_GAME
  #define ONE_GENERATION
  #define TWO_GENERATION
  #define THREE_GENERATION
elseif 4_PLAYER_GAME
  #define ONE_GENERATION
  #define TWO_GENERATION
  #define THREE_GENERATION
  #define FOUR_GENERATION
elseif 5_PLAYER_GAME
  #define ONE_GENERATION
  #define TWO_GENERATION
  #define THREE_GENERATION
  #define FOUR_GENERATION
  #define FIVE_GENERATION
elseif 6_PLAYER_GAME
  #define ONE_GENERATION
  #define TWO_GENERATION
  #define THREE_GENERATION
  #define FOUR_GENERATION
  #define FIVE_GENERATION
  #define SIX_GENERATION
elseif 7_PLAYER_GAME
  #define ONE_GENERATION
  #define TWO_GENERATION
  #define THREE_GENERATION
  #define FOUR_GENERATION
  #define FIVE_GENERATION
  #define SIX_GENERATION
  #define SEVEN_GENERATION
elseif 8_PLAYER_GAME
  #define ONE_GENERATION
  #define TWO_GENERATION
  #define THREE_GENERATION
  #define FOUR_GENERATION
  #define FIVE_GENERATION
  #define SIX_GENERATION
  #define SEVEN_GENERATION
  #define EIGHT_GENERATION
endif



/* ***************** Hill river generations ***************** */
/* Allow rivers to form at (grid, letters for X dir, numbers for Y dir) A D F H J M, 1 4 6 8 10 13 but not at A1, A9, M1, M9 i.e. not the corners. */

start_random
  percent_chance 12 #define CONFIG_NO_RIVERS
  percent_chance 88 #define CONFIG_TWO_RIVERS
  /* percent_chance 25 #define CONFIG_FOUR_RIVERS */
end_random

if CONFIG_NO_RIVERS
elseif CONFIG_TWO_RIVERS

/* Find the first of the two rivers */
  start_random
    percent_chance 33 #define CONFIG_RIVER_A4
    percent_chance 33 #define CONFIG_RIVER_A6
    percent_chance 34 #define CONFIG_RIVER_A9
  end_random
  
/* Choose the second river based off the first river (for fairness) */
  if CONFIG_RIVER_A4
    start_random
      percent_chance 50 #define CONFIG_RIVER_M6
      percent_chance 50 #define CONFIG_RIVER_M9
    end_random

  elseif CONFIG_RIVER_A6
    start_random
      percent_chance 33 #define CONFIG_RIVER_M4
      percent_chance 34 #define CONFIG_RIVER_M6
      percent_chance 33 #define CONFIG_RIVER_M9
    end_random

  elseif CONFIG_RIVER_A9
    start_random
      percent_chance 50 #define CONFIG_RIVER_M4
      percent_chance 50 #define CONFIG_RIVER_M6
    end_random

  endif
endif



/* ************************************************************************************************ PLAYER SETUP ************************************************************************************************ */


<PLAYER_SETUP>
random_placement
behavior_version 1

/* Make it so that the trees have more wood (as there are not many on the map) */
effect_amount SET_ATTRIBUTE PALMTREE ATTR_STORAGE_VALUE 200


/* so that gold and stone can be placed on beach terrain */
effect_amount SET_ATTRIBUTE cGoldMine ATTR_TERRAIN_ID 10
effect_amount SET_ATTRIBUTE cStoneMineClass ATTR_TERRAIN_ID 10

/* so that buildings can be built on beach terrain */
effect_amount SET_ATTRIBUTE BUILDING_CLASS ATTR_TERRAIN_ID 10
effect_amount SET_ATTRIBUTE FARM_CLASS ATTR_TERRAIN_ID 10
effect_amount SET_ATTRIBUTE TOWER_CLASS ATTR_TERRAIN_ID 10

/* fix the docks */
#const HARBOR 1189
effect_amount SET_ATTRIBUTE DOCK ATTR_TERRAIN_ID 6
effect_amount SET_ATTRIBUTE DOCK_F ATTR_TERRAIN_ID 6
effect_amount SET_ATTRIBUTE DOCK_C ATTR_TERRAIN_ID 6
effect_amount SET_ATTRIBUTE DOCK_I ATTR_TERRAIN_ID 6
effect_amount SET_ATTRIBUTE HARBOR ATTR_TERRAIN_ID 6

/* Make it so emus (ostriches) have less food */
effect_amount SET_ATTRIBUTE DLC_OSTRICH ATTR_STORAGE_VALUE 80

/* ********************************************************************************************** LAND GENERATION ********************************************************************************************** */

<LAND_GENERATION>



base_terrain BASE_LEVEL_TERRAIN








create_player_lands
{
  terrain_type                    PLACEHOLDER_TERRAIN 
  if TINY_MAP
    base_size                       9
  else 
    base_size                       12
  endif 
  if TINY_MAP
    number_of_tiles                 855
  else 
    number_of_tiles                 920
  endif 

  clumping_factor 15
  other_zone_avoidance_distance 5
  
  if TINY_MAP
    circle_radius 20 1
  elseif SMALL_MAP
    circle_radius 22 1
  elseif MEDIUM_MAP
    circle_radius 22 1
  elseif LARGE_MAP
    circle_radius 26 2
  elseif HUGE_MAP
    circle_radius 28 2
  elseif GIGANTIC_MAP
    circle_radius 30 3
  elseif LUDIKRIS_MAP
    circle_radius 32 4
  endif

  zone 3
  base_elevation 1
}

/* Center land  */

if TINY_MAP
create_land
{
  terrain_type                    TEMP_TERRAIN 
  base_size                       8
  land_percent                    66
  land_position                   50 50
  border_fuzziness                13
  left_border                     18
  right_border                    18
  top_border                      18
  bottom_border                   18

  min_placement_distance          21

  land_id                         4
  zone                            3
  other_zone_avoidance_distance   3
  base_elevation 1
}
else
create_land
{
  terrain_type                    TEMP_TERRAIN 
  base_size                       20
  land_percent                    66
  land_position                   50 50
  border_fuzziness                13
  left_border                     18
  right_border                    18
  top_border                      18
  bottom_border                   18

  land_id                         4
  zone                            3
  other_zone_avoidance_distance   2
  base_elevation 1
}
endif 



